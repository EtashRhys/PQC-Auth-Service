# FastAPI Settings
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_ENV=development
FASTAPI_DEBUG=true

# Security / JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (when you add SQLAlchemy)
DATABASE_URL=sqlite:///./pq_auth.db
# DATABASE_URL=postgresql://user:password@localhost/pq_auth

# Logging
LOG_LEVEL=INFO

# PQC Settings (future use)
MLKEM_PARAMETER_SET=ML-KEM-768
MLDSA_PARAMETER_SET=ML-DSA-65
